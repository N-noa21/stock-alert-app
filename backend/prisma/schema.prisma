generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  JP
  US
}

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String
  name      String?
  market    Market
  lots StockLot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockLot {
  id   Int @id @default(autoincrement())
  stockId   Int
  stock   Stock @relation(fields: [stockId],references:[id],onDelete:Cascade)

  quantity   Int
  buyPrice   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stockId])
}