generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  JP
  US
}

enum AlertDirection {
  ABOVE
  BELOW
}

model Stock {
  id     Int     @id @default(autoincrement())
  
  userId   Int
  user   User @relation(fields:[userId],references:[id],onDelete:Cascade)

  symbol String
  name   String?
  market Market

  currentPrice   Decimal?  @db.Decimal(18, 4)
  priceUpdatedAt DateTime?

  alerts StockAlert[]
  lots   StockLot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId,symbol,market])
  @@index([userId])
}

model StockLot {
  id      Int   @id @default(autoincrement())
  stockId Int
  stock   Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  quantity  Int
  buyPrice  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stockId])
}

model StockAlert {
  id      Int   @id @default(autoincrement())
  stockId Int
  stock   Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  direction   AlertDirection
  targetPrice Decimal        @db.Decimal(18, 4)
  isActive    Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stockId])
}

model User {
  id   Int @id @default(autoincrement())
  name   String
  email   String @unique
  passwordHash   String

  stocks Stock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
