generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  JP
  US
}

model Stock {
  id        Int      @id @default(autoincrement())
  symbol    String
  name      String?
  market    Market
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([symbol, market])
}
